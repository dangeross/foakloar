# Hex-encoded private key for the world author keypair.
# Leave blank on first run — the script will generate one and print it.
AUTHOR_PRIVATE_KEY=
# NSEC private key for the world author keypair.
AUTHOR_NSEC=

# Trust test authors (Phase 14) — separate keypairs for collaborator scenarios.
# Leave blank on first run — the script will generate them.
COLLAB_PRIVATE_KEY=
VOUCHED_PRIVATE_KEY=
UNTRUSTED_PRIVATE_KEY=

# Public key of the application curator (used for the /w featured list).
# Derive from AUTHOR_PRIVATE_KEY: getPublicKey(privkey)
VITE_APP_PUBKEY=

# Comma-separated relay URLs to publish to.
RELAY_URLS=wss://relay.primal.net,wss://nos.lol
