{
  "walkthrough": [
    "# Tide's End 08: Sound — Walkthrough",
    "# This world teaches Sound events: ambient, layer, effect, and sound as an action.",
    "# Uses the 'dirt' sample preset for Strudel patterns.",
    "# Start at The Dock.",
    "",
    "> look",
    "# You see The Dock. Exits: north, east.",
    "# A seagull layer sound is playing (gulls and rope creaking).",
    "",
    "> north",
    "# Arrive at Village Square. Exits: south, east, west.",
    "# No sound defined here — the dock layer fades out.",
    "",
    "> east",
    "# Arrive at The Tavern. Exit: west.",
    "# The tavern ambient sound plays (crackling fire and soft murmur).",
    "",
    "> west",
    "# Back at Village Square. Tavern ambient fades out.",
    "",
    "> west",
    "# Arrive at The Beach. Exits: east, west.",
    "# The beach ambient plays (waves and surf).",
    "# The dock seagull layer does NOT play here — layers are place-scoped.",
    "# You notice a sand coin.",
    "",
    "> flip coin",
    "# A short pickup chime effect plays (sound as action via on-interact).",
    "# The coin flashes in the light.",
    "",
    "> take coin",
    "# Taken: Sand Coin.",
    "",
    "> west",
    "# Back at The Dock via coastal path.",
    "# The seagull layer resumes.",
    "",
    "> east",
    "# Back at The Beach. Ambient waves resume.",
    "",
    "> east",
    "# Back at Village Square.",
    "",
    "> south",
    "# Back at The Dock. Seagull layer plays again.",
    "# All sound types demonstrated: ambient, layer, effect, and sound action."
